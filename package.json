{
  "name": "mugen-web-sandbox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "qa:css": "node scripts/audit_css_duplication.cjs",
    "qa:css:budget": "node scripts/audit_css_duplication.cjs --max-bytes=536051 --max-rules=2364 --max-duplicate-selector-keys=0 --max-exact-duplicate-rule-keys=0 --max-repeated-declaration-groups=119 --max-cross-file-overlaps=108 --max-src-style-overlaps=0 --max-cross-file-shadowed-rules=0",
    "qa:css:detail": "node scripts/audit_css_duplication.cjs --detail-overlaps --detail-repeated",
    "fix:css": "node scripts/audit_css_duplication.cjs --fix-exact --fix-shadowed --fix-cross-file-shadowed",
    "qa:stage": "node scripts/qa_stage_compatibility.cjs",
    "qa:stage:repository": "node scripts/qa_repository_stage_compatibility.cjs",
    "qa:smoke": "node scripts/qa_smoke.cjs",
    "qa:trace": "node scripts/qa_traces.cjs",
    "materialize:compatibility-snapshot": "node scripts/materialize_compatibility_corpus_snapshot.cjs",
    "check:boundaries": "node scripts/check_boundaries.cjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/three": "^0.184.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "typescript": "~7.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@tabler/icons": "^3.44.0",
    "jszip": "^3.10.1",
    "three": "^0.184.0"
  }
}
